  "lyrics": [
    {
      "text": "Poate am exagerat din nou",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 0
      }
    },
    {
      "text": "Amestec vise in pahar XO",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 0
      }
    },
    {
      "text": "Nu-mi fute nimeni filmu' pana n-am terminat",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 0
      }
    },
    {
      "text": "Am multe vicii, da' nu simt ca am deraiat [x2]",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 0
      }
    },
    {
      "text": "Si-a luat gagiu' de mi-a dat G-ul pe 30",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Aprind racheta zi de zi si ajung in spatiu en gros",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Pun stop, cand schimb starea",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Sunt predispus sa-mi pierd rabdarea",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "De aia imi place schimbarea",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Nu am mai dormit de ceva timp",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Ma simt ca un metronom, nu pot sa-mi ies din ritm",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Nu se compara nimic",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Cu un pic de haos pe repeat",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Unde as fi fost acum daca n-as fi innebunit?",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Moschino, bandana",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Fara dor, ma imbrac cu Prada",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Banii sunt tot bani si sunt platit sa-mi distrug viata",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Asa ca-i dau, nu stau, ca am treaba",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Imi contribui cu inca o noapte jumatate",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 1
      }
    },
    {
      "text": "Poate am exagerat din nou",
      "syllabus": [],
      "element": {
        "key": "",
        "singer": "",
        "songPartIndex": 2
      }
    },
    {
      "text": "Amestec vise in pahar XO",
      "syllabus": [],
